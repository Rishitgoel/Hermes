# ── Backend API base ──
VITE_BASE_URL_BACKEND=http://localhost:8001

# ── Keycloak (auth) ──
# Set to `true` to skip Keycloak entirely and read a mock role from
# localStorage['hermes_mock_token']. Must match the backend's KEYCLOAK_SIMULATION setting.
VITE_KEYCLOAK_SIMULATION=false

# Keycloak server + realm + frontend client.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=hermes-prod

# ── Platform routing ──
# The platform a brand-new user is onboarded to by default (mirrors the backend's
# DEFAULT_PLATFORM). Falls back to "redash" when unset. Per-platform "open" links in
# the UI now come from the backend (GET /api/platforms exposes each adapter's launch
# URL), so there's no per-platform URL to configure here anymore.
VITE_DEFAULT_PLATFORM=redash
