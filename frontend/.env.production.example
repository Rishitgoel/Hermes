# ── Backend API base ──
# In production, set this to the base URL of the backend API.
# - If the frontend and backend are hosted on the same domain (e.g., behind a reverse proxy/ingress
#   mapping /api to the backend), leave this as `/` or empty.
# - If they are hosted on separate domains, set this to the absolute backend URL (e.g. `https://api.hermes.bachatt.app`).
VITE_BASE_URL_BACKEND=/

# ── Keycloak (auth) ──
# Simulation MUST be false in production.
VITE_KEYCLOAK_SIMULATION=false

# Production Keycloak settings.
VITE_KEYCLOAK_URL=https://<keycloak-domain>
VITE_KEYCLOAK_REALM=<realm-name>
VITE_KEYCLOAK_CLIENT_ID=hermes-prod

# ── Default Platform ──
# Platform new users are onboarded to by default (mirrors the backend DEFAULT_PLATFORM).
VITE_DEFAULT_PLATFORM=redash
