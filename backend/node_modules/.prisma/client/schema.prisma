datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_HERMES")
}

generator client {
  provider = "prisma-client-js"
}

// ══════════════════════════════════════════
// GROUPS
// ══════════════════════════════════════════

model Group {
  id              String   @id @default(uuid())
  name            String   @unique // "Growth", "Retention"
  slug            String   @unique // "growth", "retention"
  description     String // What tables/data this gives access to
  icon            String? // Lucide icon name
  color           String? // Hex color for card
  externalGroupId String?  @map("external_group_id") // ID of the matching group on the target platform
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tables          String[]
  // Stored as a lowercase platform key ("redash", "aws", "jira", ...).
  // Required — set explicitly on group creation. There is no default: the
  // platform determines which adapter provisions access, so guessing it would
  // silently route requests to the wrong system. Not a Prisma enum because new
  // platforms are registered at runtime via the provisioning registry and we
  // don't want a schema migration per platform.
  platform        String

  admins         GroupAdmin[]
  accessRequests AccessRequest[]
  userAccesses   UserAccess[]

  @@map("groups")
}

model GroupAdmin {
  id         String   @id @default(uuid())
  groupId    String   @map("group_id")
  userId     String   @map("user_id") // Keycloak user ID
  userName   String   @map("user_name")
  userEmail  String   @map("user_email")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_admins")
}

// Platform-scoped admin: can manage the group admins + members of every group
// on one platform. Sits between hermes_super_admin (all platforms) and
// GroupAdmin (one group). Keycloak is the source of truth for the matching
// `hermes_platform_admin_<platform>` role; this table mirrors assignments so
// listings, notifications, and authorization work cheaply (and in simulation
// mode, where Keycloak isn't running). `platform` is a free string matching
// Group.platform and the provisioning-registry key — no FK, so onboarding a new
// platform needs no schema migration.
model PlatformAdmin {
  id         String   @id @default(uuid())
  userId     String   @map("user_id") // Keycloak user ID
  userName   String   @map("user_name")
  userEmail  String   @map("user_email")
  platform   String // "redash", "aws", ...
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@unique([userId, platform])
  @@index([platform])
  @@map("platform_admins")
}

// ══════════════════════════════════════════
// ACCESS REQUESTS
// ══════════════════════════════════════════

model AccessRequest {
  id      String @id @default(uuid())
  groupId String @map("group_id")

  // Requester (from Keycloak token)
  requesterId    String @map("requester_id")
  requesterName  String @map("requester_name")
  requesterEmail String @map("requester_email")

  // Request
  justification String
  duration      AccessDuration @default(PERMANENT)
  expiresAt     DateTime?      @map("expires_at")

  // Review
  status       RequestStatus @default(PENDING)
  reviewerId   String?       @map("reviewer_id")
  reviewerName String?       @map("reviewer_name")
  reviewNote   String?       @map("review_note")
  reviewedAt   DateTime?     @map("reviewed_at")

  // Provisioning
  provisionedAt  DateTime? @map("provisioned_at")
  provisionError String?   @map("provision_error")
  revokedAt      DateTime? @map("revoked_at")
  revokeReason   String?   @map("revoke_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group        Group        @relation(fields: [groupId], references: [id])
  auditEntries AuditEntry[]

  @@index([requesterId])
  @@index([status])
  @@index([groupId, status])
  @@index([expiresAt])
  @@map("access_requests")
}

// ══════════════════════════════════════════
// USER ACCESS (source of truth)
// ══════════════════════════════════════════

model UserAccess {
  id             String  @id @default(uuid())
  userId         String  @map("user_id")
  userName       String  @map("user_name")
  userEmail      String  @map("user_email")
  groupId        String  @map("group_id")
  externalUserId String? @map("external_user_id") // ID of this user on the target platform

  isActive  Boolean   @default(true) @map("is_active")
  grantedAt DateTime  @default(now()) @map("granted_at")
  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  grantedBy       String  @map("granted_by")
  accessRequestId String? @map("access_request_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id])

  // Removed: @@unique([userId, groupId, isActive])
  // This caused violations on repeated grant/revoke cycles.
  // Uniqueness for active access is now enforced via application logic
  // and a unique index on (userId, groupId) WHERE isActive = true.
  @@index([expiresAt, isActive])
  @@map("user_accesses")
}

// ══════════════════════════════════════════
// NOTIFICATIONS (in-app)
// ══════════════════════════════════════════

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  linkUrl   String?  @map("link_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

// ══════════════════════════════════════════
// AUDIT LOG
// ══════════════════════════════════════════

model AuditEntry {
  id              String   @id @default(uuid())
  action          String // "REQUEST_CREATED", "APPROVED", etc.
  performerId     String   @map("performer_id")
  performerName   String   @map("performer_name")
  targetUserId    String?  @map("target_user_id")
  targetUserName  String?  @map("target_user_name")
  groupId         String?  @map("group_id")
  accessRequestId String?  @map("access_request_id")
  details         Json?
  ipAddress       String?  @map("ip_address")
  createdAt       DateTime @default(now()) @map("created_at")

  accessRequest AccessRequest? @relation(fields: [accessRequestId], references: [id])

  @@index([performerId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_entries")
}

// ══════════════════════════════════════════
// USER CREATION REQUESTS
// (admin approval gate before a user is invited to Redash)
// ══════════════════════════════════════════

model UserCreationRequest {
  id String @id @default(uuid())

  // Identity (from Keycloak token). Unique on both so we never get two
  // open requests for the same person, and so the Redash sync can match
  // by email cheaply.
  userId    String @unique @map("user_id")
  userName  String @map("user_name")
  userEmail String @unique @map("user_email")

  // Request body — null while DRAFT, required when moving to PENDING.
  justification String?

  status UserCreationStatus @default(DRAFT)

  // Review fields — mirror AccessRequest so the same admin UI patterns work.
  reviewerId      String?   @map("reviewer_id")
  reviewerName    String?   @map("reviewer_name")
  reviewNote      String?   @map("review_note")
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionReason String?   @map("rejection_reason")

  // Lifecycle timestamps
  submittedAt  DateTime? @map("submitted_at")
  approvedAt   DateTime? @map("approved_at")
  inviteSentAt DateTime? @map("invite_sent_at")
  inviteError  String?   @map("invite_error")
  // Redash-issued one-time setup URL. Stored so we can surface it in Hermes
  // directly — the user can click through to set their Redash password without
  // depending on Redash's invite email.
  inviteLink   String?   @map("invite_link")
  completedAt  DateTime? @map("completed_at")

  // Populated by the Redash sync once the user exists on Redash.
  externalUserId Int? @map("external_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([userEmail])
  @@map("user_creation_requests")
}

// ══════════════════════════════════════════
// PLATFORM CACHE (synced from each platform's API)
//
// Generic, platform-keyed mirror of users/groups living on the external
// platforms Hermes provisions into (Redash today; AWS/Jira next). Each adapter
// owns the rows tagged with its own `platform` key — there is no per-platform
// table, so adding a platform needs no schema migration.
// ══════════════════════════════════════════

model PlatformExternalUser {
  id               String   @id @default(uuid())
  platform         String // "redash", "aws", ...
  externalId       String   @map("external_id") // String — AWS/Jira use non-numeric IDs
  email            String
  name             String
  isDisabled       Boolean  @default(false) @map("is_disabled")
  isPending        Boolean  @default(false) @map("is_pending") // generic "invitation pending"
  externalGroupIds String[] @map("external_group_ids") // group IDs on the platform, as strings
  metadata         Json? // platform-specific extras (ARN, etc.)
  lastSyncedAt     DateTime @map("last_synced_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([platform, externalId])
  @@unique([platform, email])
  @@index([platform, email])
  @@map("platform_external_users")
}

model PlatformExternalGroup {
  id           String   @id @default(uuid())
  platform     String
  externalId   String   @map("external_id")
  name         String
  type         String?
  memberCount  Int      @default(0) @map("member_count")
  metadata     Json?
  lastSyncedAt DateTime @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([platform, externalId])
  @@index([platform])
  @@map("platform_external_groups")
}

// ══════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════

enum AccessDuration {
  ONE_DAY
  ONE_WEEK
  ONE_MONTH
  THREE_MONTHS
  PERMANENT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROVISIONING
  PROVISIONED
  PROVISION_FAILED
  EXPIRED
  REVOKED
  // Group request was approved by an admin but the requester has not yet
  // completed their Redash setup (user-creation flow). Will auto-provision
  // when the Redash user sync detects the user.
  WAITING_FOR_SETUP
}

enum UserCreationStatus {
  DRAFT // Auto-created on first /auth/me hit; waiting for the user to submit a justification
  PENDING // User submitted; waiting for admin review
  APPROVED // Admin approved; Redash invite call is in flight (or failed and is retryable)
  REJECTED // Admin rejected; cascade-rejects the user's pending group requests
  AWAITING_SETUP // Redash invite sent; waiting for the user to click the link and complete signup
  COMPLETED // User exists on Redash; externalUserId recorded; any WAITING_FOR_SETUP group requests auto-provisioned
}
