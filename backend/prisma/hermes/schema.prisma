datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_HERMES")
}

// Two generators are BOTH required — most of src/ imports the bare `@prisma/client`
// (resolves to the default `node_modules/.prisma/client`, generated by `client_default`
// below), while a few files (admin-management.controller.ts, group.controller.ts, and
// a couple of tests) import enum types from the custom-output client at
// `../../generated/hermes` (generated by `client`). Don't remove either without first
// checking both import styles are still satisfied.
generator client {
  provider = "prisma-client-js"
  output   = "../../generated/hermes"
}

generator client_default {
  provider = "prisma-client-js"
}

// ══════════════════════════════════════════
// GROUPS
// ══════════════════════════════════════════

model Group {
  id               String           @id @default(uuid())
  name             String                           // "Growth", "Retention"
  slug             String           @unique            // "growth", "retention"
  description      String                              // What tables/data this gives access to
  icon             String?                              // Lucide icon name
  color            String?                              // Hex color for card
  externalGroupId  String?          @map("external_group_id")  // ID of the matching group on the target platform
  isActive         Boolean          @default(true) @map("is_active")
  // When true, EVERY authenticated Hermes user is an implicit member of this
  // group — no access request, no UserAccess row, no per-user account. Used to
  // let all users self-serve a shared capability (e.g. requesting Secret
  // Ingestion) while a handful of group admins still approve. Scope resolution
  // treats such a group as granted to everyone; the request flow refuses it.
  openEnrollment   Boolean          @default(false) @map("open_enrollment")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  tables           String[]
  // Stored as a lowercase platform key ("redash", "aws", "jira", ...).
  // Required — set explicitly on group creation. There is no default: the
  // platform determines which adapter provisions access, so guessing it would
  // silently route requests to the wrong system. Not a Prisma enum because new
  // platforms are registered at runtime via the provisioning registry and we
  // don't want a schema migration per platform.
  platform         String

  admins           GroupAdmin[]
  accessRequests   AccessRequest[]
  userAccesses     UserAccess[]
  levels           GroupLevel[]
  zookeeperChangeRequests ZookeeperChangeRequest[]
  secretIngestionRequests SecretIngestionRequest[]

  @@unique([platform, name])
  @@map("groups")
}

// A permission-level (subgroup) inside a Group, e.g. Credit Card → Intern / Junior / Senior.
// Each level is backed by its own external platform group (its own externalGroupId); the real
// read-only vs write distinction is configured on that external group (in Redash, on its data
// sources), so Hermes just routes a requester to the right group. A Group with zero active
// levels behaves exactly as before (request the group directly, provision to Group.externalGroupId).
model GroupLevel {
  id               String           @id @default(uuid())
  groupId          String           @map("group_id")
  name             String                              // "Intern", "Senior Dev"
  slug             String                              // "intern", "senior-dev" (unique within the group)
  description      String?
  permission       String?                             // display/audit label: "read-only", "write" (real perms live on the external group)
  externalGroupId  String?          @map("external_group_id")  // the platform group backing THIS level
  rank             Int              @default(0)         // ordering; higher = more senior (also used to pick an admin's default level)
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  accessRequests   AccessRequest[]
  userAccesses     UserAccess[]

  @@unique([groupId, slug])
  @@index([groupId])
  @@map("group_levels")
}

model GroupAdmin {
  id               String           @id @default(uuid())
  groupId          String           @map("group_id")
  userId           String           @map("user_id")           // Keycloak user ID
  userName         String           @map("user_name")
  userEmail        String           @map("user_email")
  assignedAt       DateTime         @default(now()) @map("assigned_at")
  assignedBy       String           @map("assigned_by")

  group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_admins")
}

// Platform-scoped admin: can manage the group admins + members of every group
// on one platform. Sits between hermes_super_admin (all platforms) and
// GroupAdmin (one group). Keycloak is the source of truth for the matching
// `hermes_platform_admin_<platform>` role; this table mirrors assignments so
// listings, notifications, and authorization work cheaply (and in simulation
// mode, where Keycloak isn't running). `platform` is a free string matching
// Group.platform and the provisioning-registry key — no FK, so onboarding a new
// platform needs no schema migration.
model PlatformAdmin {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")           // Keycloak user ID
  userName         String           @map("user_name")
  userEmail        String           @map("user_email")
  platform         String                                     // "redash", "aws", ...
  assignedAt       DateTime         @default(now()) @map("assigned_at")
  assignedBy       String           @map("assigned_by")

  @@unique([userId, platform])
  @@index([platform])
  @@map("platform_admins")
}

// ══════════════════════════════════════════
// ACCESS REQUESTS
// ══════════════════════════════════════════

model AccessRequest {
  id               String           @id @default(uuid())
  groupId          String           @map("group_id")
  levelId          String?          @map("level_id")   // null = group-level request (group has no levels)

  // Requester (from Keycloak token)
  requesterId      String           @map("requester_id")
  requesterName    String           @map("requester_name")
  requesterEmail   String           @map("requester_email")

  // Request
  justification    String
  duration         AccessDuration   @default(PERMANENT)
  expiresAt        DateTime?        @map("expires_at")

  // Review
  status           RequestStatus    @default(PENDING)
  reviewerId       String?          @map("reviewer_id")
  reviewerName     String?          @map("reviewer_name")
  reviewNote       String?          @map("review_note")
  reviewedAt       DateTime?        @map("reviewed_at")

  // Provisioning
  provisionedAt    DateTime?        @map("provisioned_at")
  provisionError   String?          @map("provision_error")
  revokedAt        DateTime?        @map("revoked_at")
  revokeReason     String?          @map("revoke_reason")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  group            Group            @relation(fields: [groupId], references: [id])
  level            GroupLevel?      @relation(fields: [levelId], references: [id])
  auditEntries     AuditEntry[]

  // NOTE: a partial unique index (requester_id, group_id) WHERE status IN
  // ('PENDING','WAITING_FOR_SETUP') enforces one OPEN request per (user, group);
  // partial indexes can't be declared in Prisma, so it lives in the migration
  // 20260611090000_add_open_request_unique (same pattern as user_accesses).
  @@index([requesterId])
  @@index([status])
  @@index([groupId, status])
  @@index([expiresAt])
  @@index([levelId])
  @@map("access_requests")
}

// ══════════════════════════════════════════
// USER ACCESS (source of truth)
// ══════════════════════════════════════════

model UserAccess {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  userName         String           @map("user_name")
  userEmail        String           @map("user_email")
  groupId          String           @map("group_id")
  levelId          String?          @map("level_id")          // null = legacy/group-level grant (group has no levels)
  externalUserId   String?          @map("external_user_id")  // ID of this user on the target platform

  isActive         Boolean          @default(true) @map("is_active")
  grantedAt        DateTime         @default(now()) @map("granted_at")
  expiresAt        DateTime?        @map("expires_at")
  revokedAt        DateTime?        @map("revoked_at")

  // Auto-expiry retry tracking: after MAX_EXPIRY_ATTEMPTS consecutive failed
  // deprovisions the scheduler stops retrying and force-marks the grant inactive
  // (the user may still exist on the platform — flagged for manual cleanup).
  expiryAttempts   Int              @default(0) @map("expiry_attempts")
  lastExpiryError  String?          @map("last_expiry_error")

  // Set once the pre-expiry warning notification has been sent, so the scheduler's
  // daily sweep doesn't re-notify the same grant every run until it actually expires.
  expiryWarnedAt   DateTime?        @map("expiry_warned_at")

  grantedBy        String           @map("granted_by")
  accessRequestId  String?          @map("access_request_id")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  group            Group            @relation(fields: [groupId], references: [id])
  level            GroupLevel?      @relation(fields: [levelId], references: [id])

  // Removed: @@unique([userId, groupId, isActive])
  // This caused violations on repeated grant/revoke cycles.
  // Uniqueness for active access is now enforced via application logic
  // and a unique index on (userId, groupId) WHERE isActive = true.
  // NOTE: that partial index is intentionally NOT keyed on levelId — a user holds
  // at most one active grant (one level) per group at a time.
  @@index([expiresAt, isActive])
  @@index([levelId])
  @@map("user_accesses")
}

// ══════════════════════════════════════════
// NOTIFICATIONS (in-app)
// ══════════════════════════════════════════

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  title            String
  message          String
  linkUrl          String?          @map("link_url")
  isRead           Boolean          @default(false) @map("is_read")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

// ══════════════════════════════════════════
// AUDIT LOG
// ══════════════════════════════════════════

model AuditEntry {
  id               String           @id @default(uuid())
  action           String                                     // "REQUEST_CREATED", "APPROVED", etc.
  performerId      String           @map("performer_id")
  performerName    String           @map("performer_name")
  targetUserId     String?          @map("target_user_id")
  targetUserName   String?          @map("target_user_name")
  groupId          String?          @map("group_id")
  accessRequestId  String?          @map("access_request_id")
  details          Json?
  ipAddress        String?          @map("ip_address")
  createdAt        DateTime         @default(now()) @map("created_at")

  accessRequest    AccessRequest?   @relation(fields: [accessRequestId], references: [id])

  @@index([performerId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_entries")
}

// ══════════════════════════════════════════
// USER CREATION REQUESTS
// (admin approval gate before a user is invited to Redash)
// ══════════════════════════════════════════

model UserCreationRequest {
  id               String              @id @default(uuid())

  // Identity (from Keycloak token). Unique per (identity, platform): one open
  // request per person *per platform*, so the same user can have separate
  // account-creation requests for Redash and AWS. The platform sync matches by
  // (userEmail, platform).
  userId           String              @map("user_id")
  userName         String              @map("user_name")
  userEmail        String              @map("user_email")
  // Which platform this account-creation request targets. Default "redash" for
  // back-compat with the original single-platform flow; AWS rows set "aws". Matches
  // Group.platform and the provisioning-registry key.
  platform         String              @default("redash")

  // Request body — null while DRAFT, required when moving to PENDING.
  justification    String?

  status           UserCreationStatus  @default(DRAFT)

  // Review fields — mirror AccessRequest so the same admin UI patterns work.
  reviewerId       String?             @map("reviewer_id")
  reviewerName     String?             @map("reviewer_name")
  reviewNote       String?             @map("review_note")
  reviewedAt       DateTime?           @map("reviewed_at")
  rejectionReason  String?             @map("rejection_reason")

  // Lifecycle timestamps
  submittedAt      DateTime?           @map("submitted_at")
  approvedAt       DateTime?           @map("approved_at")
  inviteSentAt     DateTime?           @map("invite_sent_at")
  inviteError      String?             @map("invite_error")
  // Redash-issued one-time setup URL. Stored so we can surface it in Hermes
  // directly — the user can click through to set their Redash password without
  // depending on Redash's invite email.
  inviteLink       String?             @map("invite_link")
  completedAt      DateTime?           @map("completed_at")

  // The user's id on the target platform, populated once they exist there.
  // String (not Int) because non-Redash platforms (AWS Identity Center) use
  // non-numeric ids; Redash stores its integer id as a string.
  externalUserId   String?             @map("external_user_id")

  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@unique([userId, platform])
  @@unique([userEmail, platform])
  @@index([status])
  @@index([userEmail])
  @@map("user_creation_requests")
}

// ══════════════════════════════════════════
// PLATFORM CACHE (synced from each platform's API)
//
// Generic, platform-keyed mirror of users/groups living on the external
// platforms Hermes provisions into (Redash today; AWS/Jira next). Each adapter
// owns the rows tagged with its own `platform` key — there is no per-platform
// table, so adding a platform needs no schema migration.
// ══════════════════════════════════════════

model PlatformExternalUser {
  id               String   @id @default(uuid())
  platform         String                                    // "redash", "aws", ...
  externalId       String   @map("external_id")              // String — AWS/Jira use non-numeric IDs
  email            String
  name             String
  isDisabled       Boolean  @default(false) @map("is_disabled")
  isPending        Boolean  @default(false) @map("is_pending")        // generic "invitation pending"
  externalGroupIds String[] @map("external_group_ids")               // group IDs on the platform, as strings
  metadata         Json?                                              // platform-specific extras (ARN, etc.)
  lastSyncedAt     DateTime @map("last_synced_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([platform, externalId])
  @@unique([platform, email])
  @@index([platform, email])
  @@map("platform_external_users")
}

model PlatformExternalGroup {
  id           String   @id @default(uuid())
  platform     String
  externalId   String   @map("external_id")
  name         String
  type         String?
  memberCount  Int      @default(0) @map("member_count")
  metadata     Json?
  lastSyncedAt DateTime @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([platform, externalId])
  @@index([platform])
  @@map("platform_external_groups")
}

// ══════════════════════════════════════════
// ZOOKEEPER CONFIGURATION CHANGE REQUESTS
//
// Approval-only config management for ZooKeeper: a user stages draft changes to
// znode data (under paths their grant covers, with write perms) and submits them
// as a request; an admin approves; only then are they applied via Hermes' admin
// connection. Apply is synchronous on approval, so there is no resting APPROVED
// state — the transient is APPLYING, terminals are APPLIED / APPLY_FAILED / REJECTED.
// ══════════════════════════════════════════

model ZookeeperChangeRequest {
  id             String           @id @default(uuid())
  requesterId    String           @map("requester_id")
  requesterName  String           @map("requester_name")
  requesterEmail String           @map("requester_email")
  // Primary group (first of groupIds) — kept for the FK/relation + simple display.
  groupId        String?          @map("group_id")
  // Every group whose paths this request touches. Changes can span several of the
  // user's groups; the request is routed to (and reviewable by) the admins of all of
  // them. Used for notify + the reviewer's pending-list filter (hasSome).
  groupIds       String[]         @map("group_ids")
  status         ZkChangeStatus   @default(PENDING)

  // Array of changes, each: { path, action, oldValue, newValue, groupId, groupName,
  //   decision?: "APPROVED"|"REJECTED", applied?, error? }
  // action: "SET" | "CREATE" | "DELETE" | "CLEAR"
  // Reviewers decide each change independently; applyApproved writes the approved ones
  // and marks the rest rejected. `applied`/`error`/`decision` are written back on review.
  changes        Json

  justification  String?

  // Review fields (same pattern as AccessRequest)
  reviewerId     String?          @map("reviewer_id")
  reviewerName   String?          @map("reviewer_name")
  reviewNote     String?          @map("review_note")
  reviewedAt     DateTime?        @map("reviewed_at")

  // Execution result
  applyError     String?          @map("apply_error")   // first/summary error when APPLY_FAILED
  appliedAt      DateTime?        @map("applied_at")

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  group          Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([requesterId])
  @@index([groupId])   // admin listing filters by the groups they can review
  @@map("zookeeper_change_requests")
}

// ══════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════

enum AccessDuration {
  ONE_DAY
  ONE_WEEK
  ONE_MONTH
  THREE_MONTHS
  PERMANENT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROVISIONING
  PROVISIONED
  PROVISION_FAILED
  EXPIRED
  REVOKED
  // Group request was approved by an admin but the requester has not yet
  // completed their Redash setup (user-creation flow). Will auto-provision
  // when the Redash user sync detects the user.
  WAITING_FOR_SETUP
}

enum UserCreationStatus {
  DRAFT             // Auto-created on first /auth/me hit; waiting for the user to submit a justification
  PENDING           // User submitted; waiting for admin review
  APPROVED          // Admin approved; Redash invite call is in flight (or failed and is retryable)
  REJECTED          // Admin rejected; cascade-rejects the user's pending group requests
  AWAITING_SETUP    // Redash invite sent; waiting for the user to click the link and complete signup
  COMPLETED         // User exists on Redash; externalUserId recorded; any WAITING_FOR_SETUP group requests auto-provisioned
}

enum ZkChangeStatus {
  PENDING            // Submitted; awaiting admin review
  APPLYING           // Review accepted; apply is in flight (transient)
  APPLIED            // Every change approved and applied (terminal)
  PARTIALLY_APPLIED  // Some changes approved+applied, others rejected (terminal)
  APPLY_FAILED       // One or more APPROVED changes failed to apply (retryable)
  REJECTED           // Every change rejected (terminal)
}

enum SecretIngestionStatus {
  PENDING
  APPLYING
  APPLIED
  PARTIALLY_APPLIED
  APPLY_FAILED
  REJECTED
}

model SecretIngestionRequest {
  id             String                @id @default(uuid())
  // Human-friendly, monotonically increasing handle shown in the UI as "#12" — a stable,
  // orderable reference the requester and reviewer both see (the UUID id is not referenceable).
  // Global across instances (Postgres serial); the platform badge already distinguishes accounts.
  requestNumber  Int                   @unique @default(autoincrement()) @map("request_number")
  requesterId    String                @map("requester_id")
  requesterName  String                @map("requester_name")
  requesterEmail String                @map("requester_email")
  groupId        String?               @map("group_id")
  // Which Secret Ingestion instance (AWS account) this request targets: "secrets" (prod + QA)
  // or "secrets-sandbox". Tagged directly on the row rather than derived from the group so it
  // survives the group relation's onDelete: SetNull, and so the review queue / apply path
  // resolve the correct AWS account without a join. Existing rows default to "secrets".
  platform       String                @default("secrets")
  secretName     String                @map("secret_name")
  entries        Json                  // Array of { key, value, decision?: "APPROVED"|"REJECTED", applied?, error? }
  justification  String?
  reviewerId     String?               @map("reviewer_id")
  reviewerName   String?               @map("reviewer_name")
  reviewNote     String?               @map("review_note")
  reviewedAt     DateTime?             @map("reviewed_at")
  applyError     String?               @map("apply_error")
  appliedAt      DateTime?             @map("applied_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  status         SecretIngestionStatus @default(PENDING)

  // infra-deployment GitHub PR mirror (see infra-repo-sync.service.ts). The PR lifecycle
  // tracks the Hermes request: opened (draft) on submit, merged on approve, closed on
  // reject, left open on a retryable APPLY_FAILED. All nullable — a request whose secret
  // has no key-enumerated consumer in the repo simply carries infraSyncState = SKIPPED.
  infraPrNumber  Int?                  @map("infra_pr_number")
  infraPrUrl     String?               @map("infra_pr_url")
  infraPrNodeId  String?               @map("infra_pr_node_id")
  infraBranch    String?               @map("infra_branch")
  infraSyncState String?               @map("infra_sync_state") // OPEN | MERGED | CLOSED | SKIPPED | FAILED
  infraSyncNote  String?               @map("infra_sync_note")
  // Requester-selected manifest files to edit: Array of { path, manifestRef, format }.
  // Null = fall back to the live auto-resolved consumer set at PR time.
  infraTargets   Json?                 @map("infra_targets")

  group          Group?                @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([requesterId])
  @@index([groupId])
  @@index([platform])
  @@map("secret_ingestion_requests")
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}


