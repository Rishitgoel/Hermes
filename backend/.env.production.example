# ── App configuration ──
NODE_ENV=production
PORT=8001

# ── Database ──
# Configure your production Hermes database connection.
# Recommendation: Add connection pooling parameters (&connection_limit=10&pool_timeout=30)
DATABASE_URL_HERMES="postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>?schema=public&connection_limit=10&pool_timeout=30"

# ── Keycloak (auth) ──
# Simulation MUST be false in production
KEYCLOAK_SIMULATION=false

# Keycloak JWT verification endpoints (must match production identity provider)
KEYCLOAK_JWKS_URI=https://<keycloak-domain>/realms/<realm-name>/protocol/openid-connect/certs
KEYCLOAK_ISSUER=https://<keycloak-domain>/realms/<realm-name>

# REQUIRED in production. Startup will fail if this is not set when NODE_ENV=production.
# This validates the JWT audience claim to prevent replay attacks.
KEYCLOAK_AUDIENCE=hermes-prod

# Keycloak Admin API Client setup (used to verify client/roles at boot)
KEYCLOAK_ADMIN_URL=https://<keycloak-domain>
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=<set-me>

# ── Platform routing ──
# Default platform for new users (e.g. redash, aws)
DEFAULT_PLATFORM=redash

# ── Redash ──
REDASH_BASE_URL=https://redash.bachatt.app
REDASH_API_KEY=<set-me>
REDASH_SIMULATION=false

# ── Slack ──
SLACK_WEBHOOK_URL=<set-me-optional>
SLACK_BOT_TOKEN=<set-me-optional>
SLACK_SIMULATION=false

# ── Email (AWS SES) ──
# Set simulation to false to send emails.
EMAIL_SIMULATION=false
# Verified SES sender address (e.g., "Hermes <no-reply@bachatt.app>")
EMAIL_FROM=no-reply@bachatt.app
# Optional: reply-to address
# EMAIL_REPLY_TO=

# ── Frontend & CORS ──
# Update these to match the production domain of your frontend
FRONTEND_URL=https://hermes.bachatt.app
ALLOWED_ORIGINS=https://hermes.bachatt.app

# ── AWS SDK Configuration ──
# Prefer ECS Task Roles or IAM Roles for Service Accounts (IRSA) to authenticate.
# If running in AWS, leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty.
# If running outside AWS, supply a least-privileges IAM user credentials.
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AWS Secrets Manager secret name to pull configuration overrides from (optional)
# AWS_SECRET_NAME=Hermes-Prod

# ── AWS IAM Identity Center provisioning (the `aws` adapter) ──
AWS_SIMULATION=false
# AWS Identity Store ID (Console: IAM Identity Center -> Settings)
AWS_IDENTITY_STORE_ID=<set-me-starts-with-d->
# Region where IAM Identity Center is configured
AWS_IDENTITY_CENTER_REGION=ap-south-1
# Portal start URL (e.g. https://d-xxxx.awsapps.com/start)
AWS_ACCESS_PORTAL_URL=https://<identity-store-id>.awsapps.com/start

# ── ZooKeeper provisioning (the `zookeeper` adapter) ──
# Hermes manages per-znode digest ACLs. SAFETY: the adapter falls back to its
# in-process simulation whenever ZOOKEEPER_CONNECT_STRING is empty OR
# ZOOKEEPER_SIMULATION=true — set BOTH deliberately. Leaving SIMULATION unset while a
# stale CONNECT_STRING is present would point Hermes at the wrong ensemble, so keep
# this block explicit in every environment.
ZOOKEEPER_SIMULATION=false
# Ensemble connect string, e.g. "zk-0:2181,zk-1:2181".
ZOOKEEPER_CONNECT_STRING=<set-me-host:2181>
# Root znode path Hermes creates its backing group nodes under.
ZOOKEEPER_ROOT_PATH=/hermes
# The admin digest "user:password" Hermes authenticates as (needs ADMIN on the managed
# znodes). Treat as a secret — prefer AWS Secrets Manager over a plaintext value here.
ZOOKEEPER_ADMIN_AUTH=<set-me-user:password>

# ── Reverse Proxy / Trust Proxy ──
# Set this so req.ip represents the real client IP, ensuring rate limiting works properly.
# 1 = trust 1 upstream proxy (e.g. AWS ALB, CloudFront, Nginx reverse proxy).
TRUST_PROXY=1
