# ── App ──
NODE_ENV=development
PORT=8001

# ── Database ──
# Local Postgres exposed by docker-compose on host port 15433.
DATABASE_URL_HERMES="postgresql://hermes_user:hermes_pass@localhost:15433/hermes?schema=public"

# ── Keycloak (auth) ──
# Set to `true` to bypass Keycloak and accept Bearer super_admin / group_admin / user.
# Must be `false` in production; the backend forces simulation off when NODE_ENV=production.
KEYCLOAK_SIMULATION=false

# JWT verification endpoints
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/master/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8080/realms/master
# REQUIRED in production — validates the JWT `aud` claim so a token minted for another
# client in the same realm can't be replayed against Hermes (startup FAILS if this is
# unset when NODE_ENV=production). Optional in dev/simulation.
# KEYCLOAK_AUDIENCE=hermes-prod

# Admin API client (used by keycloak-setup at boot to ensure client/roles exist)
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=<set-me>

# ── Platform routing ──
# The platform a brand-new user is onboarded to on first login (the row /auth/me
# auto-drafts) and the implicit target when an API caller omits `platform`. Must
# match a registered provisioning adapter key (today: redash, aws). Falls back to
# "redash" when unset. This is the single knob for the default platform — services
# read config.platform.default rather than hardcoding it.
DEFAULT_PLATFORM=redash

# ── Redash ──
# Default: live mode against the local self-hosted Redash stack started by
# docker-compose.yml (Redash + workers + scheduler on host port 5500). After
# `docker compose up -d redis redash-postgres && docker compose run --rm redash
# create_db && docker compose up -d redash redash-worker redash-scheduler`,
# open http://localhost:5500, create the org as admin, then copy the API key
# from Profile → API Key into REDASH_API_KEY below.
#
# To roll over to bachatt.app once an admin key is provisioned:
#   REDASH_BASE_URL=https://redash.bachatt.app
#   REDASH_API_KEY=<bachatt-admin-key>
# Restart the backend; no code change required.
#
# To fall back to mock data (no Redash running), set REDASH_SIMULATION=true.
REDASH_BASE_URL=http://localhost:5500
REDASH_API_KEY=<set-me>
REDASH_SIMULATION=false

# ── Slack notifications ──
# Incoming webhook → posts to ONE shared channel (team feed). Optional; leave
# unset to disable the channel ping.
SLACK_WEBHOOK_URL=
# Bot token (xoxb-…) → enables per-user DMs (needs scopes users:read.email +
# chat:write). Leave unset for now; DMs simulate (log only) without it.
SLACK_BOT_TOKEN=
# Force DM simulation (log instead of send) even if a bot token is set.
SLACK_SIMULATION=true

# ── Email (AWS SES) ──
# Simulate (log instead of send) until you have a verified SES sender.
# Set EMAIL_SIMULATION=false + a verified EMAIL_FROM in production to go live.
EMAIL_SIMULATION=true
# Verified SES sender, e.g. "Hermes <no-reply@bachatt.app>". Required to send.
EMAIL_FROM=
# Optional reply-to address.
# EMAIL_REPLY_TO=
# SES region — defaults to AWS_REGION (below) if unset.
# SES_REGION=ap-south-1
# Dev only: address used as the "super admin" recipient in simulation so admin
# emails/DMs have somewhere to go locally.
# SIM_ADMIN_EMAIL=you@example.com

# ── Frontend / CORS ──
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── AWS (shared: Secrets Manager, SES, IAM Identity Center) ──
# AWS_REGION is shared by Secrets Manager, SES, and the IAM Identity Center adapter.
# Credentials: in production prefer the ECS task role / IRSA (leave the keys unset and
# the SDK's default chain resolves the role). Use static keys ONLY when Hermes runs
# outside AWS — and then they MUST be a dedicated least-privilege IAM user
# (hermes-provisioner), NEVER the root account.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=<set-me>
# AWS_SECRET_ACCESS_KEY=<set-me>
# AWS_SECRET_NAME=Hermes-Prod

# ── AWS IAM Identity Center provisioning (the `aws` adapter) ──
# Simulate (mock, no AWS calls) until you have an Identity Center instance + the
# hermes-provisioner credentials. While AWS_SIMULATION=true (or AWS_IDENTITY_STORE_ID
# is unset) the adapter never touches AWS, so the whole grant/revoke/expire flow is
# testable locally.
AWS_SIMULATION=true
# Identity Store ID, e.g. d-1234567890 (Console: IAM Identity Center → Settings).
# AWS_IDENTITY_STORE_ID=d-xxxxxxxxxx
# Region the Identity Center instance lives in (defaults to AWS_REGION if unset).
# Must be an AWS region CODE (e.g. us-east-1, ap-south-1) — NOT the console display
# name. Find it in IAM Identity Center → Settings (the region shown in the console URL).
# AWS_IDENTITY_CENTER_REGION=us-east-1
# Optional — only for future account-assignment automation (sso-admin). Unused today.
# AWS_SSO_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxx
# AWS access portal (SSO start) URL — put in the onboarding email so a newly created
# user can set their password on first sign-in (Console: IAM Identity Center →
# Settings → "AWS access portal URL").
# AWS_ACCESS_PORTAL_URL=https://d-xxxxxxxxxx.awsapps.com/start

# ── Security / rate limiting (optional overrides) ──
# Rate limiting is ON by default in prod, OFF in dev. Force one way with:
# ENABLE_RATE_LIMIT=true
# Helmet is ON by default — set to `false` only if it conflicts with a proxy in front.
# SECURITY_HELMET=true
