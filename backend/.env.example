# ── App ──
NODE_ENV=development
PORT=8001
# Optional: logger level (default is 'info')
# LOG_LEVEL=info

# ── Database ──
# Local Postgres exposed by docker-compose on host port 15433.
DATABASE_URL_HERMES="postgresql://hermes_user:hermes_pass@localhost:15433/hermes?schema=public"

# ── Keycloak (auth) ──
# Set to `true` to bypass Keycloak and accept Bearer super_admin / group_admin / user.
# Must be `false` in production; the backend forces simulation off when NODE_ENV=production.
KEYCLOAK_SIMULATION=false

# JWT verification endpoints
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/master/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8080/realms/master
# REQUIRED in production — validates the JWT `aud` claim so a token minted for another
# client in the same realm can't be replayed against Hermes (startup FAILS if this is
# unset when NODE_ENV=production). Optional in dev/simulation.
# KEYCLOAK_AUDIENCE=hermes-prod

# Admin API client (used by keycloak-setup at boot to ensure client/roles exist)
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=<set-me>

# ── Platform routing ──
# The platform a brand-new user is onboarded to on first login (the row /auth/me
# auto-drafts) and the implicit target when an API caller omits `platform`. Must
# match a registered provisioning adapter key (today: redash, aws). Falls back to
# "redash" when unset. This is the single knob for the default platform — services
# read config.platform.default rather than hardcoding it.
DEFAULT_PLATFORM=redash

# ── Redash ──
# Default: live mode against the local self-hosted Redash stack started by
# docker-compose.yml (Redash + workers + scheduler on host port 5500). After
# `docker compose up -d redis redash-postgres && docker compose run --rm redash
# create_db && docker compose up -d redash redash-worker redash-scheduler`,
# open http://localhost:5500, create the org as admin, then copy the API key
# from Profile → API Key into REDASH_API_KEY below.
#
# To roll over to bachatt.app once an admin key is provisioned:
#   REDASH_BASE_URL=https://redash.bachatt.app
#   REDASH_API_KEY=<bachatt-admin-key>
# Restart the backend; no code change required.
#
# To fall back to mock data (no Redash running), set REDASH_SIMULATION=true.
REDASH_BASE_URL=http://localhost:5500
REDASH_API_KEY=<set-me>
REDASH_SIMULATION=false

# ── Redash QA (optional second instance) ──
# A second, independent Redash server registered as its own platform key
# ("redash-qa") alongside prod ("redash"). Leave REDASH_QA_BASE_URL unset to
# skip registering this instance entirely (no dead adapter, no UI chooser).
# Set both to point Hermes at a QA Redash deployment.
# REDASH_QA_BASE_URL=https://redash-qa.bachatt.app
# REDASH_QA_API_KEY=<set-me>
# REDASH_QA_SIMULATION=false

# ── Slack notifications ──
# Incoming webhook → posts to ONE shared channel (team feed). Optional; leave
# unset to disable the channel ping.
SLACK_WEBHOOK_URL=
# Bot token (xoxb-…) → enables per-user DMs (needs scopes users:read.email +
# chat:write). Leave unset for now; DMs simulate (log only) without it.
SLACK_BOT_TOKEN=
# Force DM simulation (log instead of send) even if a bot token is set.
SLACK_SIMULATION=true

# ── Email (AWS SES) ──
# Simulate (log instead of send) until you have a verified SES sender.
# Set EMAIL_SIMULATION=false + a verified EMAIL_FROM in production to go live.
EMAIL_SIMULATION=true
# Verified SES sender, e.g. "Hermes <no-reply@bachatt.app>". Required to send.
EMAIL_FROM=
# Optional reply-to address.
# EMAIL_REPLY_TO=
# SES region — defaults to AWS_REGION (below) if unset.
# SES_REGION=ap-south-1
# Dev only: address used as the "super admin" recipient in simulation so admin
# emails/DMs have somewhere to go locally.
# SIM_ADMIN_EMAIL=you@example.com

# ── Frontend / CORS ──
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── AWS (shared: Secrets Manager, SES, IAM Identity Center) ──
# Toggle AWS integrations completely (default is true if not false)
# AWS_ENABLED=false
# AWS_REGION is shared by Secrets Manager, SES, and the IAM Identity Center adapter.
# Credentials: in production prefer the ECS task role / IRSA (leave the keys unset and
# the SDK's default chain resolves the role). Use static keys ONLY when Hermes runs
# outside AWS — and then they MUST be a dedicated least-privilege IAM user
# (hermes-provisioner), NEVER the root account.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=<set-me>
# AWS_SECRET_ACCESS_KEY=<set-me>
# AWS_PROFILE=hermes-dev
# Preferred name for the AWS Secrets Manager secret (prevents clashing with admin-panel)
# HERMES_AWS_SECRET_NAME=Hermes-Prod
# AWS_SECRET_NAME=Hermes-Prod

# ── AWS Secrets Ingestion (the `secrets` adapter — prod + QA, one AWS account) ──
# Secrets Ingestion simulation flag. Simulation is ON by default if true, or if no region is resolved.
SECRETS_INGESTION_SIMULATION=true
# Regional target for AWS Secrets Manager for secret ingestion. Defaults to AWS_REGION if unset.
# SECRETS_INGESTION_REGION=ap-south-1
# Optional HTTPS endpoint override (VPC/PrivateLink/FIPS)
# SECRETS_INGESTION_ENDPOINT=

# ── AWS Secrets Ingestion — SANDBOX instance (the `secrets-sandbox` adapter, a SECOND AWS account) ──
# Opt-in second Secret Ingestion instance. The UI shows a prod/sandbox chooser once this is
# enabled. Enabled when SECRETS_SANDBOX_REGION is set (go-live), SECRETS_SANDBOX_SIMULATION=true
# (local two-instance testing), or SECRETS_SANDBOX_PROFILE is named — otherwise it's skipped and
# no second card/chooser appears.
#
# Credentials: the sandbox uses the AWS SDK's DEFAULT credential chain (no dedicated key vars).
# To resolve a DIFFERENT account than prod, point SECRETS_SANDBOX_PROFILE at a named AWS profile
# (in ~/.aws/config) whose credentials/role belong to the sandbox account.
# SECRETS_SANDBOX_REGION=ap-south-1
# SECRETS_SANDBOX_PROFILE=hermes-sandbox
# Optional HTTPS endpoint override (VPC/PrivateLink/FIPS). Must be https://.
# SECRETS_SANDBOX_ENDPOINT=
# Force simulation for the sandbox (mock store, no AWS). Set true locally to see the chooser
# without a real second account.
# SECRETS_SANDBOX_SIMULATION=true

# ── infra-deployment PR mirror (Secret Ingestion → GitHub) — PROD instance (`secrets`) ──
# When a Secret Ingestion request adds a NEW key, Hermes opens a PR on the infra-deployment
# repo registering the key name in the manifests that consume the secret (see
# infra-repo-sync.service.ts). Simulation is ON by default when true, or when no token is set —
# so local dev never pushes to the real repo. Go live: INFRA_REPO_SIMULATION=false + a PAT with
# the scopes listed below.
#
# Required PAT scopes (classic) or fine-grained permissions:
#   Classic PAT:  repo (full control) — needed for contents:write, pull_requests:write,
#                 and the GraphQL markPullRequestReadyForReview mutation.
#   Fine-grained: contents:write + pull_requests:write + metadata:read
#                 + read:org (required for markPullRequestReadyForReview GraphQL on private repos)
#
# If the infra-deployment repo has branch protection rules that require reviews or
# status checks, the PAT must also have admin/bypass permissions — otherwise the
# auto-merge will fail with a 405.
INFRA_REPO_SIMULATION=true
# INFRA_REPO_TOKEN=github_pat_xxx
# INFRA_REPO_OWNER=bachatt-app
# INFRA_REPO_NAME=infra-deployment
# INFRA_REPO_BASE_BRANCH=main
# INFRA_REPO_API_URL=https://api.github.com
# Auto-merge: when true, Hermes merges the deployment PR automatically the moment
# it's ready (on ingestion approval or drift resolve). When false (default), the PR
# is opened but left for a human to review and merge manually on GitHub.
# INFRA_REPO_AUTO_MERGE=false

# ── infra-deployment PR mirror — SANDBOX instance (`secrets-sandbox`) ──
# The sandbox mirrors approved keys into its OWN GitHub repo (a separate infra repo). This is
# WIRED but OFF until that repo exists: it's enabled only when SECRETS_SANDBOX_INFRA_REPO_NAME is
# set (go-live), or SECRETS_SANDBOX_INFRA_REPO_ENABLED=true (local simulation testing). While off,
# sandbox requests write to AWS only and open no PR. Same PAT scopes as prod (see above).
# SECRETS_SANDBOX_INFRA_REPO_ENABLED=false
# SECRETS_SANDBOX_INFRA_REPO_SIMULATION=true
# SECRETS_SANDBOX_INFRA_REPO_TOKEN=github_pat_xxx
# SECRETS_SANDBOX_INFRA_REPO_OWNER=bachatt-app
# SECRETS_SANDBOX_INFRA_REPO_NAME=infra-deployment-sandbox
# SECRETS_SANDBOX_INFRA_REPO_BASE_BRANCH=main
# SECRETS_SANDBOX_INFRA_REPO_API_URL=https://api.github.com
# Auto-merge for the sandbox instance (same behavior as INFRA_REPO_AUTO_MERGE above).
# SECRETS_SANDBOX_INFRA_REPO_AUTO_MERGE=false

# ── AWS IAM Identity Center provisioning (the `aws` adapter) ──
# Simulate (mock, no AWS calls) until you have an Identity Center instance + the
# hermes-provisioner credentials. While AWS_SIMULATION=true (or AWS_IDENTITY_STORE_ID
# is unset) the adapter never touches AWS, so the whole grant/revoke/expire flow is
# testable locally.
AWS_SIMULATION=true
# Identity Store ID, e.g. d-1234567890 (Console: IAM Identity Center → Settings).
# AWS_IDENTITY_STORE_ID=d-xxxxxxxxxx
# Region the Identity Center instance lives in (defaults to AWS_REGION if unset).
# Must be an AWS region CODE (e.g. us-east-1, ap-south-1) — NOT the console display
# name. Find it in IAM Identity Center → Settings (the region shown in the console URL).
# AWS_IDENTITY_CENTER_REGION=us-east-1
# Optional — only for future account-assignment automation (sso-admin). Unused today.
# AWS_SSO_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxx
# AWS access portal (SSO start) URL — put in the onboarding email so a newly created
# user can set their password on first sign-in (Console: IAM Identity Center →
# Settings → "AWS access portal URL").
# AWS_ACCESS_PORTAL_URL=https://d-xxxxxxxxxx.awsapps.com/start

# ── ZooKeeper provisioning (the `zookeeper` adapter) ──
# Access is per-znode ACLs (digest scheme): a Hermes group is a znode path, a level
# is "<path>#<perms>" (e.g. /hermes/credit-card#cdrw), and each user's identity is a
# digest credential Hermes mints. Simulate (in-process mock, no real ZooKeeper) until
# you have an ensemble — ZOOKEEPER_SIMULATION=true (or an unset connect string) keeps
# the whole grant/revoke/expire flow testable locally. Going live also needs a wired
# ZooKeeper client in zookeeper.service.ts.
ZOOKEEPER_SIMULATION=true
# Ensemble connect string, e.g. zk-0:2181,zk-1:2181 (host:port[,host:port...]).
# ZOOKEEPER_CONNECT_STRING=localhost:2181
# Root znode path Hermes creates auto-generated backing group nodes under (used by
# createExternalGroup to derive a path from a group name, e.g. "Credit Card" →
# /credit-card when rootPath is /). Defaults to `/`. Admins can also paste any
# absolute path directly when creating a group — this only affects the auto-derivation.
# ZOOKEEPER_ROOT_PATH=/
# Super-digest "user:password" Hermes authenticates as to manage ACLs (needs ADMIN on
# the target znodes). Required only when going live.
# ZOOKEEPER_ADMIN_AUTH=hermes:change-me

# ── Security / rate limiting (optional overrides) ──
# Rate limiting is ON by default in prod, OFF in dev. Force one way with:
# ENABLE_RATE_LIMIT=true
# Helmet is ON by default — set to `false` only if it conflicts with a proxy in front.
# SECURITY_HELMET=true
# How many reverse-proxy hops to trust (ALB, CloudFront, nginx). Set this so
# req.ip is the real client IP (not the proxy's) — otherwise rate limiting
# shares a single bucket for all clients behind the proxy.
# 0 = trust nothing (local dev default), 1 = one proxy (typical ALB setup).
# TRUST_PROXY=1
