{
  "name": "hermes-backend",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "prisma:generate": "prisma generate --schema=prisma/hermes/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/hermes/schema.prisma",
    "prisma:seed": "ts-node prisma/hermes/seed.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-identitystore": "^3.1063.0",
    "@aws-sdk/client-secrets-manager": "^3.1053.0",
    "@aws-sdk/client-sesv2": "^3.1056.0",
    "@prisma/client": "^6.8.2",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jwks-rsa": "^3.2.0",
    "node-cron": "^4.2.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.71"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.19",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "prisma": "^6.8.2",
    "testcontainers": "^12.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.8"
  }
}
