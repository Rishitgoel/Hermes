# Copy to `.env` at the repo root (gitignored) on the server. docker-compose.prod.yml
# reads this automatically — these are the values docker-compose.prod.yml itself needs,
# separate from backend/.env.production and frontend/.env.production.

# Hermes' own Postgres (NOT Redash's — Redash is your real, already-hosted instance,
# if you're running one; not needed at all if Redash stays simulated).
POSTGRES_USER=hermes_user
POSTGRES_PASSWORD=<generate-a-long-random-password>
POSTGRES_DB=hermes

# No Basic Auth / gate-key vars needed here anymore — this deployment mode assumes
# every platform is simulated (a public demo with no real credentials behind it).
# If you ever wire a real integration back in, put a gate back in front of the
# site before doing so (see git history for the Basic Auth + X-Hermes-Gate setup).
